# =============================================================
# Flooring Hot Topics GPT - Middleware Config
# =============================================================

# Bearer token used by GPT Actions to authenticate to this API.
# Generate a long random string and configure the same value in
# the ChatGPT GPT editor → Actions → Authentication.
API_BEARER_TOKEN=changeme-replace-with-long-random-string

# Adapter mode:
#   byok  - users bring their own Semrush key via /register (recommended for shared GPT)
#   real  - server uses one shared SEMRUSH_API_KEY for everyone
#   mock  - return deterministic fake data (no key needed)
#   csv   - only allow data via /import-csv (no live source)
DATA_SOURCE_MODE=byok

# Shared-mode Semrush API key (only used when DATA_SOURCE_MODE=real).
# Leave blank for byok / mock / csv.
SEMRUSH_API_KEY=

# ----- BYOK (衣帽间) settings -----
# Path to SQLite file holding per-user encrypted Semrush keys + quota.
DATABASE_PATH=./byok.db

# Fernet encryption key for stored Semrush keys.  Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IF YOU CHANGE THIS, ALL EXISTING TOKENS BECOME UNREADABLE.
KEY_ENCRYPTION_SECRET=

# Per-user quotas (set 0 to disable a limit)
DEFAULT_DAILY_QUOTA=50
DEFAULT_MONTHLY_QUOTA=800

# Validate the user's Semrush key when they register, by issuing one
# cheap real call.  Costs ~10 API units per registration.  Highly
# recommended in production.  Set to false to skip validation in dev.
VALIDATE_SEMRUSH_ON_REGISTER=true

# Semrush base URL (rarely needs changing)
SEMRUSH_BASE_URL=https://api.semrush.com/

# Default analysis country (Semrush database code: us, uk, de, ...)
DEFAULT_DATABASE=us

# Cap on rows fetched per competitor per call (Semrush units cost)
SEMRUSH_PAGES_LIMIT=50
SEMRUSH_KEYWORDS_LIMIT=200

# Where exported files are written (relative to project root)
EXPORT_DIR=./exports

# Public base URL where this API is reachable.  GPT Actions need
# an HTTPS URL.  For local dev expose via ngrok / cloudflared.
PUBLIC_BASE_URL=https://your-public-host.example.com
